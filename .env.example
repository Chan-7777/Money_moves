# PayPal credentials — developer.paypal.com → Apps & Credentials
# Use sandbox values for testing, live values for production
PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID
PAYPAL_SECRET=REPLACE_WITH_YOUR_PAYPAL_SECRET
PAYPAL_ENV=sandbox

# ConvertAPI — convertapi.com → Authentication → Production Token
CONVERTAPI_SECRET=REPLACE_WITH_YOUR_CONVERTAPI_SECRET

# Resend — resend.com → API Keys
RESEND_API_KEY=REPLACE_WITH_YOUR_RESEND_API_KEY
